# ============================================================
#  NEXUS AI - CRYPTO FARMER  |  Environment Variables
#  Copy this file to .env and fill in your values
#  NEVER commit your real .env file to git!
# ============================================================

# ── Flask ────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
FLASK_ENV=development

# ── Wallet (KEEP YOUR PRIVATE KEY SECRET) ────────────────────
WALLET_ADDRESS=0xYourWalletAddressHere
WALLET_PRIVATE_KEY=0xYourPrivateKeyHere

# ── RPC Endpoints ─────────────────────────────────────────────
# Ethereum mainnet  (get a free key at https://infura.io or https://alchemy.com)
ETH_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_KEY
# BNB Smart Chain
BSC_RPC_URL=https://bsc-dataseed.binance.org/
# Polygon
POLYGON_RPC_URL=https://polygon-rpc.com/

# ── Price & Data APIs ─────────────────────────────────────────
# CoinGecko (optional – free tier available at https://www.coingecko.com/en/api)
COINGECKO_API_KEY=

# ── Bot Settings ──────────────────────────────────────────────
# Minimum profit in USD before executing a trade
MIN_PROFIT_USD=5.0
# Maximum gas price in Gwei (protection against gas spikes)
MAX_GAS_GWEI=50
# Slippage tolerance in percent (e.g. 0.5 = 0.5%)
SLIPPAGE_PERCENT=0.5
# Maximum USD value per trade
MAX_TRADE_USD=500
# Seconds between opportunity scans
SCAN_INTERVAL_SECONDS=15
# Set to "true" to simulate trades without sending real transactions
DRY_RUN=true

# ── Enabled Strategies ────────────────────────────────────────
STRATEGY_ARBITRAGE=true
STRATEGY_YIELD_FARMING=true
STRATEGY_LIQUIDITY_MINING=true

# ── Enabled Chains ────────────────────────────────────────────
CHAIN_ETH=true
CHAIN_BSC=true
CHAIN_POLYGON=true
