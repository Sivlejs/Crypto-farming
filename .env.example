# ══════════════════════════════════════════════════════════════
#  Nexus AI — Environment Configuration
#  Copy to .env and fill in your values
# ══════════════════════════════════════════════════════════════

# ── Bot Behaviour ─────────────────────────────────────────────
DRY_RUN=true                   # true = simulate only (no real txs). Set false to go LIVE.
MIN_PROFIT_USD=2.00            # Minimum estimated profit to execute a trade
MAX_GAS_GWEI=80                # Never pay more than this gas price
SLIPPAGE_PERCENT=0.5           # Max slippage tolerance (%)
MAX_TRADE_USD=10000            # Max USD value per single trade
SCAN_INTERVAL_SECONDS=10       # Fallback scan interval (block-triggered is faster)

# ── Wallet ────────────────────────────────────────────────────
WALLET_ADDRESS=0xYOUR_WALLET_ADDRESS
WALLET_PRIVATE_KEY=            # KEEP SECRET — used to sign transactions

# ── Blockchain RPCs ───────────────────────────────────────────
# Get free keys at: https://alchemy.com  or  https://infura.io
ETH_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_KEY
BSC_RPC_URL=https://bsc-dataseed1.binance.org/
POLYGON_RPC_URL=https://polygon-mainnet.infura.io/v3/YOUR_INFURA_KEY

# Enable/disable chains
CHAIN_ETH=true
CHAIN_BSC=true
CHAIN_POLYGON=true

# ── Strategies ────────────────────────────────────────────────
STRATEGY_ARBITRAGE=true
STRATEGY_YIELD_FARMING=true
STRATEGY_LIQUIDITY_MINING=true
STRATEGY_LIQUIDATION=true

# ── MEV / Speed ───────────────────────────────────────────────
# Flashbots: separate key for signing bundles (NOT your wallet key)
# Generate: python -c "from eth_account import Account; a=Account.create(); print(a.key.hex())"
FLASHBOTS_SIGNING_KEY=

# bloXroute: ultra-fast block propagation (optional)
BLOXROUTE_AUTH_HEADER=

# Deployed FlashArbitrage.sol contract addresses (optional — enables capital-free arb)
FLASH_CONTRACT_ETH=
FLASH_CONTRACT_POLYGON=

# ── Payout — Coinbase API ─────────────────────────────────────
# Create API key at: https://www.coinbase.com/settings/api
COINBASE_API_KEY=
COINBASE_API_SECRET=
COINBASE_ACCOUNT_ID=           # Your Coinbase USD or BTC account ID

# ── Payout — Cash App / Lightning (Bitcoin) ───────────────────
# Your Bitcoin or Lightning address for Cash App payouts
LIGHTNING_ADDRESS=             # e.g. yourname@cashapp.com  OR  lnurl1dp...  OR  bc1q...
# Alby/LNBITS API key (optional — enables programmatic Lightning sends)
ALBY_API_KEY=

# ── Payout Settings ───────────────────────────────────────────
PAYOUT_THRESHOLD_USD=10.00     # Auto-sweep when pending profits reach this amount
PAYOUT_CHAIN=ethereum          # Chain to collect profits on
PAYOUT_TOKEN=USDC              # Token to accumulate (USDC, USDT, WETH, etc.)
PAYOUT_WALLET_ADDRESS=         # On-chain destination (if not using Coinbase/Lightning)

# ── Prices ────────────────────────────────────────────────────
COINGECKO_API_KEY=             # Optional — increases rate limit

# ── Infrastructure ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0   # Used for caching + Celery task queue
PORT=10000

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO                 # DEBUG, INFO, WARNING, ERROR
