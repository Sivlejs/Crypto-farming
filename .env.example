# ══════════════════════════════════════════════════════════════
#  Nexus AI — Environment Configuration
#  Copy to .env and fill in your values
#  ⚠️ IMPORTANT: Set DRY_RUN=false only when ready for live production
# ══════════════════════════════════════════════════════════════

# ── Bot Behaviour ─────────────────────────────────────────────
DRY_RUN=false                  # false = LIVE mode (real txs). Set true for simulation.
                               # ⚠️ WARNING: Live mode executes real transactions!
MIN_PROFIT_USD=1.00            # Minimum estimated profit to execute a trade (lowered for more opportunities)
MAX_GAS_GWEI=80                # Never pay more than this gas price
SLIPPAGE_PERCENT=0.5           # Max slippage tolerance (%)
MAX_TRADE_USD=10000            # Max USD value per single trade
SCAN_INTERVAL_SECONDS=10       # Fallback scan interval (block-triggered is faster)

# ── Wallet ────────────────────────────────────────────────────
WALLET_ADDRESS=0xYOUR_WALLET_ADDRESS
WALLET_PRIVATE_KEY=            # KEEP SECRET — used to sign transactions

# ── Blockchain RPCs ───────────────────────────────────────────
# Get free keys at: https://alchemy.com  or  https://infura.io
ETH_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_KEY
BSC_RPC_URL=https://bsc-dataseed1.binance.org/
POLYGON_RPC_URL=https://polygon-mainnet.infura.io/v3/YOUR_INFURA_KEY

# Enable/disable chains
CHAIN_ETH=true
CHAIN_BSC=true
CHAIN_POLYGON=true

# ── Strategies ────────────────────────────────────────────────
STRATEGY_ARBITRAGE=true
STRATEGY_YIELD_FARMING=true
STRATEGY_LIQUIDITY_MINING=true
STRATEGY_LIQUIDATION=true
STRATEGY_POW_MINING=true           # Enable PoW cryptocurrency mining with vGPU

# ── PoW Mining ────────────────────────────────────────────────
# Configure for vGPU/GPU mining (competitive with dedicated hardware)
# Pool URL format: stratum+tcp://pool.example.com:3333
MINING_POOL_URL=stratum+tcp://pool.2miners.com:2020    # 2Miners ETC pool (default)
MINING_POOL_USER=0xYOUR_WALLET_ADDRESS.nexusworker     # Your wallet + worker name
MINING_POOL_PASSWORD=x             # Usually 'x' or empty
MINING_ALGORITHM=etchash           # etchash, kawpow, autolykos2, kheavyhash recommended for GPU
MINING_THREADS=0                   # 0 = auto-detect CPU cores
MINING_INTENSITY=90                # 1-100 (90% recommended for production stability)
MINING_PAYOUT_ADDRESS=0xYOUR_WALLET_ADDRESS   # Wallet address for mining rewards

# ── Virtual Server Mining Optimizations ───────────────────────
# Optimized for cloud providers with GPU (AWS, GCP, Azure, Render, etc.)
MINING_ADAPTIVE_MODE=true          # Auto-adjust threads/intensity based on load
MINING_MAX_CPU_PERCENT=85          # Maximum CPU usage target (85% leaves headroom for stability)

# ── GPU Mining (Hardware Competitive) ─────────────────────────
# Enable vGPU/GPU mining to compete with dedicated hardware
MINING_USE_GPU=true                # Enable GPU mining (auto-detects NVIDIA/AMD)
MINING_GPU_DEVICES=                # GPU device IDs (empty = all, e.g. "0,1,2")
MINING_EXPECTED_HASHRATE_MHS=100   # Expected hashrate in MH/s (for profit calculations)
MINING_GPU_POWER_WATTS=250         # GPU power consumption estimate (watts)
MINING_ELECTRICITY_COST_KWH=0.10   # Electricity cost $/kWh
MINING_BACKUP_POOLS=stratum+tcp://etc.2miners.com:1010,stratum+tcp://us-etc.2miners.com:1010   # Backup pools

# ── Profit Switching ──────────────────────────────────────────
# Auto-switch to most profitable coin based on market conditions
MINING_PROFIT_SWITCHING=true       # Enable automatic profit-based coin switching
MINING_PROFIT_SWITCH_THRESHOLD=5   # Min % improvement to trigger switch (lowered for responsiveness)

# ── AI Mining Optimization ────────────────────────────────────
# Enable AI-powered mining optimization for maximum efficiency
MINING_AI_OPTIMIZATION=true        # Use machine learning for optimal mining parameters

# ── Virtual GPU (vGPU) ────────────────────────────────────────
# Enable virtual GPU simulation for cloud environments without physical GPUs
MINING_VGPU_ENABLED=true           # Enable vGPU for cloud mining (Render, AWS, GCP, Azure)
MINING_VGPU_COUNT=1                # Number of virtual GPU devices (1-8)
MINING_VGPU_MEMORY_MB=4096         # Simulated memory per vGPU device (2048-32768)

# ── REAL vGPU COMPUTE (NEW) ──────────────────────────────────
# Enable REAL hash computation instead of simulation
MINING_VGPU_REAL_COMPUTE=true      # true = perform ACTUAL hash computations (recommended)
                                   # false = legacy simulation mode (not for real mining)

# Compute mode determines how real computation is performed:
# - auto: Auto-detect best option (GPU > XMRig > CPU)
# - cpu_real: Built-in CPU computation (always available)
# - external: Use external miner (XMRig, T-Rex, lolMiner)
# - cloud: Rent cloud GPUs via vast.ai or RunPod
MINING_VGPU_COMPUTE_MODE=auto

# ── Cloud GPU Rental (vast.ai / RunPod) ──────────────────────
# For REAL GPU mining without owning hardware
# Get vast.ai API key at: https://vast.ai/console/account/
VASTAI_API_KEY=
# Get RunPod API key at: https://www.runpod.io/console/user/settings
RUNPOD_API_KEY=
CLOUD_GPU_MAX_COST_PER_HOUR=0.50   # Max hourly cost in USD for cloud GPU
CLOUD_GPU_PREFERRED_MODEL=RTX_4090 # Preferred GPU model (RTX_4090, A100, H100)

# ── XMRig Integration (CPU Mining) ───────────────────────────
# XMRig is the best CPU miner for RandomX (Monero) and other algorithms
XMRIG_PATH=                        # Path to xmrig (auto-detected if not set)
XMRIG_API_PORT=18080               # XMRig HTTP API port for stats
XMRIG_ALGORITHM=rx/0               # RandomX algorithm (rx/0 for Monero)

# ── MEV / Speed ───────────────────────────────────────────────
# Flashbots: separate key for signing bundles (NOT your wallet key)
# Generate: python -c "from eth_account import Account; a=Account.create(); print(a.key.hex())"
FLASHBOTS_SIGNING_KEY=

# bloXroute: ultra-fast block propagation (optional)
BLOXROUTE_AUTH_HEADER=

# Deployed FlashArbitrage.sol contract addresses (optional — enables capital-free arb)
FLASH_CONTRACT_ETH=
FLASH_CONTRACT_POLYGON=

# ── Payout — Coinbase API ─────────────────────────────────────
# Create API key at: https://www.coinbase.com/settings/api
COINBASE_API_KEY=
COINBASE_API_SECRET=
COINBASE_ACCOUNT_ID=           # Your Coinbase USD or BTC account ID

# ── Payout — Cash App / Lightning (Bitcoin) ───────────────────
# Your Bitcoin or Lightning address for Cash App payouts
LIGHTNING_ADDRESS=             # e.g. yourname@cashapp.com  OR  lnurl1dp...  OR  bc1q...
# Alby/LNBITS API key (optional — enables programmatic Lightning sends)
ALBY_API_KEY=

# ── Payout Settings ───────────────────────────────────────────
PAYOUT_THRESHOLD_USD=10.00     # Auto-sweep when pending profits reach this amount
PAYOUT_CHAIN=ethereum          # Chain to collect profits on
PAYOUT_TOKEN=USDC              # Token to accumulate (USDC, USDT, WETH, etc.)
PAYOUT_WALLET_ADDRESS=         # On-chain destination (if not using Coinbase/Lightning)

# ── Prices ────────────────────────────────────────────────────
COINGECKO_API_KEY=             # Optional — increases rate limit

# ── OpenAI / Nexus Chat ───────────────────────────────────────
# Set this to enable GPT-4o intelligent responses from Nexus AI Chat
# Get key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o            # or gpt-4o-mini, gpt-3.5-turbo, etc.
# Optional: override for OpenAI-compatible APIs (Groq, Together, LM Studio)
OPENAI_BASE_URL=               # e.g. https://api.groq.com/openai

# ── Voice / TTS ───────────────────────────────────────────────
# ElevenLabs: premium neural text-to-speech for Nexus AI voice
# Get key at: https://elevenlabs.io
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=           # Leave blank to use default "Rachel" voice
VOICE_WAKE_WORD=nexus          # Wake word for voice activation

# ── Additional Chains ─────────────────────────────────────────
# Enable Layer 2 and alt-L1 chains for more farming opportunities
CHAIN_ARBITRUM=false
CHAIN_OPTIMISM=false
CHAIN_BASE=false
CHAIN_AVALANCHE=false
CHAIN_FANTOM=false
CHAIN_GNOSIS=false

ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
OPTIMISM_RPC_URL=https://mainnet.optimism.io
BASE_RPC_URL=https://mainnet.base.org
AVALANCHE_RPC_URL=https://api.avax.network/ext/bc/C/rpc
FANTOM_RPC_URL=https://rpc.ftm.tools/
GNOSIS_RPC_URL=https://rpc.gnosischain.com/

# ── Gas Oracle / Timing ───────────────────────────────────────
GAS_ORACLE_SAMPLES=100         # Historical gas samples to keep
GAS_SAMPLE_INTERVAL=60         # Seconds between gas price samples

# ── Infrastructure ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0   # Used for caching + Celery task queue
PORT=10000

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO                 # DEBUG, INFO, WARNING, ERROR
