      "targets": [{"expr": "vgpu_gpu_utilization_pct", "legendFormat": "{{worker}} / GPU{{gpu_index}}", "refId": "A"}]
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "decmbytes", "color": {"mode": "palette-classic"}}, "overrides": []},
